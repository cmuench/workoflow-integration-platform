{% extends 'base.html.twig' %}

{% block title %}{{ 'integration.connect'|trans|default('Connect') }} {{ server.name }} - Workoflow{% endblock %}

{% block body %}
<div class="integrations-page">
    <div class="integration-form-container">
        <div class="integration-form">
            <div class="form-section">
                <div class="quick-connect-header">
                    <img src="/images/logos/mcp-servers/{{ server.logo }}"
                         alt="{{ server.name }}"
                         class="quick-connect-logo"
                         onerror="this.style.display='none'">
                    <div class="section-title" style="justify-content: center;">
                        {{ 'integration.connect'|trans|default('Connect') }} {{ server.name }}
                    </div>
                    <p class="quick-connect-description">
                        {{ 'integration.quick_connect_name_description'|trans|default('Give this connection a unique name so you can identify it later, especially if you connect multiple instances of the same server.') }}
                    </p>
                </div>

                <form method="post" action="{{ path('app_remote_mcp_quick_connect_confirm', {serverKey: serverKey}) }}">
                    <div class="form-group">
                        <label class="form-label" for="quick_connect_name">
                            {{ 'integration.instance_name'|trans|default('Instance Name') }} <span class="quick-connect-required">*</span>
                        </label>
                        <input type="text"
                               id="quick_connect_name"
                               name="name"
                               class="form-control"
                               value="{{ suggestedName }}"
                               required
                               autocomplete="off"
                               placeholder="{{ server.name }}">
                        <div class="form-help">{{ 'integration.quick_connect_name_hint'|trans|default('e.g., "Atlassian Rovo — valantic" or "Sentry — production"') }}</div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="quick_connect_context">
                            {{ 'integration.instance_context'|trans|default('Instance Context') }}
                            <span style="color: var(--text-muted); font-weight: 400;">({{ 'common.optional'|trans }})</span>
                        </label>
                        <textarea id="quick_connect_context"
                                  name="instance_context"
                                  class="form-control"
                                  rows="2"
                                  placeholder="{{ 'integration.instance_context_placeholder'|trans|default('e.g., valanticgroup.atlassian.net — Engineering workspace') }}"></textarea>
                        <div class="form-help">{{ 'integration.instance_context_hint'|trans|default('Additional context for AI agents to differentiate this instance, e.g., workspace URL, team name, or environment') }}</div>
                    </div>

                    <div class="form-actions">
                        <a href="{{ path('app_skills') }}" class="btn btn-secondary">
                            {{ 'action.cancel'|trans|default('Cancel') }}
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-arrow-right"></i>
                            {{ 'integration.continue_to_authorization'|trans|default('Continue to Authorization') }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
.quick-connect-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border-color);
}

.quick-connect-logo {
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-md);
}

.quick-connect-description {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    max-width: 500px;
    margin: var(--space-sm) auto 0;
    line-height: 1.5;
}

.quick-connect-required {
    color: var(--color-primary);
}
</style>
{% endblock %}
