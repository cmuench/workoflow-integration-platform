{% extends 'base.html.twig' %}

{% block title %}{{ 'kb.title'|trans }} - Workoflow{% endblock %}

{% block body %}
<div class="dashboard-page files-page">
    <div class="dashboard-container">
        <div class="files-header">
            <div class="files-header-top">
                <h1>{{ 'kb.title'|trans }}</h1>
            </div>
            <div class="files-explanation">
                <p id="tabExplanation">{{ 'kb.explanation'|trans }}</p>
            </div>
        </div>

        {# Tab Navigation #}
        <div class="kb-tabs">
            <button class="kb-tab active" data-tab="upload" onclick="switchTab('upload')">
                <i class="fas fa-upload"></i> {{ 'kb.tab.upload'|trans }}
            </button>
            <button class="kb-tab" data-tab="sitemap" onclick="switchTab('sitemap')">
                <i class="fas fa-sitemap"></i> {{ 'kb.tab.sitemap'|trans }}
            </button>
            <button class="kb-tab" data-tab="snippet" onclick="switchTab('snippet')">
                <i class="fas fa-file-alt"></i> {{ 'kb.tab.snippet'|trans }}
            </button>
            <button class="kb-tab" data-tab="sources" onclick="switchTab('sources')">
                <i class="fas fa-layer-group"></i> {{ 'kb.tab.sources'|trans }}
            </button>
        </div>

        {# Upload Tab #}
        <div class="kb-tab-content active" id="tab-upload">
            <div id="dropzone" class="dropzone">
                <div class="dropzone-content">
                    <p>{{ 'kb.upload.drag_drop'|trans }}</p>
                    <input type="file" id="fileInput" multiple accept=".pdf,.docx,.txt,.md" class="hidden">
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('fileInput').click()">
                        {{ 'kb.upload.select_files'|trans }}
                    </button>
                </div>
            </div>
            <div id="fileList" class="file-list"></div>
            <div class="form-group" id="documentTypeGroup" style="display:none; margin-top: var(--space-sm);">
                <label for="documentType">{{ 'kb.upload.document_type'|trans }}</label>
                <select id="documentType" class="form-control">
                    <option value="general">{{ 'kb.upload.type_general'|trans }}</option>
                    <option value="project_knowledge">{{ 'kb.upload.type_project_knowledge'|trans }}</option>
                </select>
            </div>
            <div class="form-group" id="sourceUrlGroup" style="display:none; margin-top: var(--space-sm);">
                <label for="sourceUrl" style="font-size: var(--text-sm);">{{ 'kb.upload.source_url'|trans|default('Source URL (optional)') }}</label>
                <input type="url" id="sourceUrl" class="form-control" placeholder="https://...">
                <p style="font-size: var(--text-xs); margin-top: 2px; color: var(--text-muted);">{{ 'kb.upload.source_url_hint'|trans|default('Link to the original source (e.g., GitLab repo, internal page)') }}</p>
            </div>
            <div class="file-info">
                <p>{{ 'kb.upload.allowed_types'|trans }}: PDF, DOCX, TXT, MD</p>
                <p>{{ 'kb.upload.max_size'|trans }}: 50 MB</p>
            </div>
            <div class="kb-section">
                <button type="button" class="btn btn-primary" id="uploadBtn" disabled>
                    <span class="spinner hidden" id="uploadSpinner"></span>
                    {{ 'kb.upload.upload'|trans }}
                </button>
            </div>

            {# Upload Pipeline (filtered to uploads) #}
            <div class="kb-section">
                <div class="kb-section-header">
                    <h2>{{ 'kb.documents.title'|trans }}</h2>
                </div>
                <div class="kb-filter-bar" id="filterBar-upload">
                    <div class="kb-filter-row">
                        <div class="kb-filter-group">
                            <label for="searchInput-upload" class="kb-filter-label">{{ 'kb.filter.search'|trans }}</label>
                            <input type="text" id="searchInput-upload" class="kb-filter-input" placeholder="{{ 'kb.filter.search_placeholder'|trans }}" oninput="onSearchInput('upload')">
                        </div>
                        <div class="kb-filter-group">
                            <label for="docTypeFilter" class="kb-filter-label">{{ 'kb.filter.document_type'|trans }}</label>
                            <select id="docTypeFilter" class="kb-filter-input" onchange="onDocTypeFilterChange()">
                                <option value="all">{{ 'kb.filter.all_types'|trans }}</option>
                                <option value="general">{{ 'kb.upload.type_general'|trans }}</option>
                                <option value="project_knowledge">{{ 'kb.upload.type_project_knowledge'|trans }}</option>
                            </select>
                        </div>
                    </div>
                    <div class="kb-bulk-actions" id="bulkActions-upload" style="display:none;">
                        <span class="kb-bulk-count" id="bulkCount-upload">0 {{ 'kb.bulk.selected'|trans|default('selected') }}</span>
                        <button type="button" class="btn btn-danger btn-small" onclick="bulkDelete('upload')">
                            <i class="fas fa-trash"></i> {{ 'kb.bulk.delete_selected'|trans }}
                        </button>
                        <button type="button" class="btn btn-secondary btn-small" onclick="clearSelection('upload')">
                            {{ 'kb.bulk.clear_selection'|trans }}
                        </button>
                    </div>
                </div>
                <div id="documentsTable-upload">
                    <div class="empty-state"><p>{{ 'kb.documents.loading'|trans }}</p></div>
                </div>
                <div id="pagination-upload" class="kb-pagination"></div>
            </div>
        </div>

        {# Sitemap Tab #}
        <div class="kb-tab-content" id="tab-sitemap">
            <div class="form-group">
                <label for="sitemapUrl">{{ 'kb.sitemap.url_label'|trans }}</label>
                <div class="kb-sitemap-row">
                    <input type="url" id="sitemapUrl" class="form-control" placeholder="https://example.com/sitemap.xml">
                    <button type="button" class="btn btn-primary" id="startCrawlBtn" onclick="startCrawl()">
                        <span class="spinner hidden" id="crawlSpinner"></span>
                        {{ 'kb.sitemap.start_crawl'|trans }}
                    </button>
                </div>
            </div>

            <div id="crawlJobsContainer" class="kb-section">
                <h3>{{ 'kb.sitemap.active_crawls'|trans }}</h3>
                <div id="crawlJobsList"></div>
            </div>

            {# Indexed Domains (moved here from global) #}
            <div class="kb-section">
                <div class="kb-section-header">
                    <h2>{{ 'kb.domains.title'|trans }}</h2>
                </div>
                <div id="domainsTable">
                    <div class="empty-state"><p>{{ 'kb.domains.loading'|trans }}</p></div>
                </div>
            </div>

            {# Web crawl documents #}
            <div class="kb-section">
                <div class="kb-section-header">
                    <h2>{{ 'kb.documents.title'|trans }}</h2>
                </div>
                <div class="kb-filter-bar" id="filterBar-web_crawl">
                    <div class="kb-filter-row">
                        <div class="kb-filter-group">
                            <label for="searchInput-web_crawl" class="kb-filter-label">{{ 'kb.filter.search'|trans }}</label>
                            <input type="text" id="searchInput-web_crawl" class="kb-filter-input" placeholder="{{ 'kb.filter.search_placeholder'|trans }}" oninput="onSearchInput('web_crawl')">
                        </div>
                    </div>
                    <div class="kb-bulk-actions" id="bulkActions-web_crawl" style="display:none;">
                        <span class="kb-bulk-count" id="bulkCount-web_crawl">0 {{ 'kb.bulk.selected'|trans|default('selected') }}</span>
                        <button type="button" class="btn btn-danger btn-small" onclick="bulkDelete('web_crawl')">
                            <i class="fas fa-trash"></i> {{ 'kb.bulk.delete_selected'|trans }}
                        </button>
                        <button type="button" class="btn btn-secondary btn-small" onclick="clearSelection('web_crawl')">
                            {{ 'kb.bulk.clear_selection'|trans }}
                        </button>
                    </div>
                </div>
                <div id="documentsTable-web_crawl">
                    <div class="empty-state"><p>{{ 'kb.documents.loading'|trans }}</p></div>
                </div>
                <div id="pagination-web_crawl" class="kb-pagination"></div>
            </div>
        </div>

        {# Snippet Tab #}
        <div class="kb-tab-content" id="tab-snippet">
            <div class="form-group">
                <label for="snippetTitle">{{ 'kb.snippet.title_label'|trans }}</label>
                <input type="text" id="snippetTitle" class="form-control" placeholder="{{ 'kb.snippet.title_placeholder'|trans }}">
            </div>
            <div class="form-group">
                <label for="snippetText">{{ 'kb.snippet.text_label'|trans }}</label>
                <textarea id="snippetText" class="form-control" rows="8" placeholder="{{ 'kb.snippet.text_placeholder'|trans }}"></textarea>
            </div>
            <div class="form-group">
                <label for="snippetSourceUrl" style="font-size: var(--text-sm);">{{ 'kb.upload.source_url'|trans|default('Source URL (optional)') }}</label>
                <input type="url" id="snippetSourceUrl" class="form-control" placeholder="https://...">
                <p style="font-size: var(--text-xs); margin-top: 2px; color: var(--text-muted);">{{ 'kb.upload.source_url_hint'|trans|default('Link to the original source (e.g., GitLab repo, internal page)') }}</p>
            </div>
            <button type="button" class="btn btn-primary" id="saveSnippetBtn" disabled onclick="saveSnippet()">
                <span class="spinner hidden" id="snippetSpinner"></span>
                {{ 'kb.snippet.save'|trans }}
            </button>

            {# Snippet documents #}
            <div class="kb-section">
                <div class="kb-section-header">
                    <h2>{{ 'kb.documents.title'|trans }}</h2>
                </div>
                <div class="kb-filter-bar" id="filterBar-snippet">
                    <div class="kb-filter-row">
                        <div class="kb-filter-group">
                            <label for="searchInput-snippet" class="kb-filter-label">{{ 'kb.filter.search'|trans }}</label>
                            <input type="text" id="searchInput-snippet" class="kb-filter-input" placeholder="{{ 'kb.filter.search_placeholder'|trans }}" oninput="onSearchInput('snippet')">
                        </div>
                    </div>
                    <div class="kb-bulk-actions" id="bulkActions-snippet" style="display:none;">
                        <span class="kb-bulk-count" id="bulkCount-snippet">0 {{ 'kb.bulk.selected'|trans|default('selected') }}</span>
                        <button type="button" class="btn btn-danger btn-small" onclick="bulkDelete('snippet')">
                            <i class="fas fa-trash"></i> {{ 'kb.bulk.delete_selected'|trans }}
                        </button>
                        <button type="button" class="btn btn-secondary btn-small" onclick="clearSelection('snippet')">
                            {{ 'kb.bulk.clear_selection'|trans }}
                        </button>
                    </div>
                </div>
                <div id="documentsTable-snippet">
                    <div class="empty-state"><p>{{ 'kb.documents.loading'|trans }}</p></div>
                </div>
                <div id="pagination-snippet" class="kb-pagination"></div>
            </div>
        </div>

        {# Sources Tab #}
        <div class="kb-tab-content" id="tab-sources">
            <div class="kb-section">
                <div class="kb-section-header">
                    <h2>{{ 'kb.sources.title'|trans }}</h2>
                    <button type="button" class="btn btn-small btn-secondary" onclick="loadSources()">
                        <i class="fas fa-sync-alt"></i> {{ 'kb.sources.refresh'|trans }}
                    </button>
                </div>
                <div id="sourcesTable">
                    <div class="empty-state"><p>{{ 'kb.sources.loading'|trans }}</p></div>
                </div>
            </div>
        </div>

    </div>
</div>

{# View Snippet Modal #}
<div class="modal" id="snippetViewModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">{{ 'kb.snippet.view_title'|trans }}</h3>
            <button type="button" class="modal-close" onclick="hideSnippetViewModal()">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>{{ 'kb.snippet.title_label'|trans }}</label>
                <p id="snippetViewTitleText" style="color: var(--text-primary); padding: var(--space-sm) 0;"></p>
            </div>
            <div class="form-group">
                <label>{{ 'kb.snippet.text_label'|trans }}</label>
                <pre id="snippetViewContentText" style="white-space: pre-wrap; word-wrap: break-word; background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: var(--border-radius); padding: var(--space-md); color: var(--text-primary); font-family: var(--font-sans); font-size: var(--text-sm); max-height: 400px; overflow-y: auto;"></pre>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="hideSnippetViewModal()">{{ 'action.close'|trans }}</button>
        </div>
    </div>
</div>

{# Edit Snippet Modal #}
<div class="modal" id="snippetEditModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">{{ 'kb.snippet.edit_title'|trans }}</h3>
            <button type="button" class="modal-close" onclick="hideSnippetEditModal()">&times;</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label for="snippetEditTitleInput">{{ 'kb.snippet.title_label'|trans }}</label>
                <input type="text" id="snippetEditTitleInput" class="form-control">
            </div>
            <div class="form-group">
                <label for="snippetEditTextInput">{{ 'kb.snippet.text_label'|trans }}</label>
                <textarea id="snippetEditTextInput" class="form-control" rows="8"></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="hideSnippetEditModal()">{{ 'action.cancel'|trans }}</button>
            <button type="button" class="btn btn-primary" id="snippetEditSaveBtn" onclick="saveSnippetEdit()">
                <span class="spinner hidden" id="snippetEditSpinner"></span>
                {{ 'action.save'|trans }}
            </button>
        </div>
    </div>
</div>

<style>
/* Tabs */
.kb-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 0;
    border-bottom: 1px solid var(--border-color);
}
.kb-tab {
    padding: 0.75rem 1.5rem;
    border: none;
    background: none;
    cursor: pointer;
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    color: var(--text-muted);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all 0.2s;
}
.kb-tab:hover {
    color: var(--text-primary);
}
.kb-tab.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
    font-weight: 600;
}
.kb-tab i {
    margin-right: 0.5rem;
}

/* Tab content */
.kb-tab-content {
    display: none;
    padding: 1.5rem 0;
}
.kb-tab-content.active {
    display: block;
}

/* Section headers */
.kb-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}
.kb-section-header h2 {
    font-size: var(--text-lg);
    font-weight: 600;
    margin: 0;
    color: var(--text-primary);
}

/* Pagination */
.kb-pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
}
.kb-pagination button {
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border-color);
    background: var(--bg-card);
    color: var(--text-secondary);
    border-radius: var(--border-radius);
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    transition: all 0.2s;
}
.kb-pagination button:hover {
    background: var(--bg-card-hover);
    color: var(--text-primary);
}
.kb-pagination button.active {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
}

/* Status badges — dark-theme friendly */
.status-badge {
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.025em;
}
.status-pending   { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
.status-processing { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
.status-completed  { background: rgba(16, 185, 129, 0.15); color: #10b981; }
.status-failed     { background: rgba(239, 68, 68, 0.15);  color: #ef4444; }
.status-uploading  { background: rgba(34, 211, 238, 0.15); color: #22d3ee; display: inline-flex; align-items: center; gap: 0.4rem; }
.status-uploading .badge-spinner {
    display: inline-block; width: 10px; height: 10px;
    border: 1.5px solid rgba(34, 211, 238, 0.3); border-top-color: #22d3ee;
    border-radius: 50%; animation: spin 0.8s linear infinite;
}
.row-uploading { opacity: 0.85; }
.status-discovering { background: rgba(168, 85, 247, 0.15); color: #a855f7; }
.status-crawling   { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
.status-upload     { background: rgba(59, 130, 246, 0.1);  color: #60a5fa; }
.status-snippet    { background: rgba(168, 85, 247, 0.1);  color: #c084fc; }
.status-web_crawl  { background: rgba(16, 185, 129, 0.1);  color: #6ee7b7; }

/* Domain rows */
.domain-row { cursor: pointer; }
.domain-row:hover { background: var(--bg-card-hover); }
.domain-pages { display: none; }
.domain-pages.expanded { display: table-row; }
.domain-toggle { transition: transform 0.2s; display: inline-block; }
.domain-toggle.expanded { transform: rotate(90deg); }

/* Form controls — match platform dark theme (scoped like .integration-form-container) */
.files-page .form-control {
    background: var(--input-background);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    padding: var(--space-sm) var(--space-md);
    transition: var(--transition);
    width: 100%;
}
.files-page .form-control::placeholder {
    color: var(--text-muted);
}
.files-page .form-control:focus {
    border-color: var(--color-primary);
    outline: none;
    box-shadow: 0 0 0 2px rgba(255, 107, 53, 0.15);
}
.files-page textarea.form-control {
    min-height: 180px;
    resize: vertical;
}
.files-page .form-group {
    margin-bottom: var(--space-lg);
}
.files-page .form-group label {
    display: block;
    font-weight: 600;
    font-size: var(--text-sm);
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
}

/* Sections */
.kb-section {
    margin-top: 1.5rem;
}

/* Sitemap input row */
.kb-sitemap-row {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
}
.kb-sitemap-row .form-control {
    flex: 1;
}

/* KB Filter Bar */
.kb-filter-bar {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-md);
}
.kb-filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: flex-end;
}
.kb-filter-group {
    flex: 1;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs, 0.25rem);
}
.kb-filter-label {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 500;
}
.kb-filter-input {
    background: var(--input-background);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    padding: var(--space-sm) var(--space-md);
    color: var(--text-primary);
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    transition: var(--transition);
    width: 100%;
}
.kb-filter-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(255, 107, 53, 0.15);
}
.kb-filter-input::placeholder {
    color: var(--text-muted);
}

/* Bulk Actions */
.kb-bulk-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--border-color);
}
.kb-bulk-count {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 500;
}

/* Checkbox in table */
.kb-checkbox {
    width: 18px;
    height: 18px;
    accent-color: var(--color-primary);
    cursor: pointer;
}
th.kb-cb-col, td.kb-cb-col {
    width: 40px;
    text-align: center;
    padding: 0.5rem;
}

/* Pagination info */
.kb-pagination-info {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-top: var(--space-sm);
}
.kb-pagination button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
}

@media (max-width: 768px) {
    .kb-filter-row { flex-direction: column; }
    .kb-filter-group { width: 100%; min-width: 100%; }
}
</style>

<script>
const API_BASE = '{{ path('app_knowledge_base') }}api';
let refreshInterval = null;
let crawlRefreshInterval = null;
let allDocuments = [];
let activeTab = 'upload';
const VALID_TABS = ['upload', 'sitemap', 'snippet', 'sources'];

// Per-tab pagination, selection, search
const DOCS_PER_PAGE = 20;
const tabPages = { upload: 1, web_crawl: 1, snippet: 1 };
const tabSelections = { upload: new Set(), web_crawl: new Set(), snippet: new Set() };
const tabSearchQueries = { upload: '', web_crawl: '', snippet: '' };
let docTypeFilter = 'all';
let searchTimeout = null;
const TAB_EXPLANATIONS = {
    upload: {{ 'kb.tab_explanation.upload'|trans|json_encode|raw }},
    sitemap: {{ 'kb.tab_explanation.sitemap'|trans|json_encode|raw }},
    snippet: {{ 'kb.tab_explanation.snippet'|trans|json_encode|raw }},
    sources: {{ 'kb.tab_explanation.sources'|trans|json_encode|raw }},
};

// Tab switching with URL hash persistence
function switchTab(tab) {
    if (!VALID_TABS.includes(tab)) tab = 'upload';
    activeTab = tab;
    document.querySelectorAll('.kb-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.kb-tab-content').forEach(c => c.classList.remove('active'));
    document.querySelector(`.kb-tab[data-tab="${tab}"]`).classList.add('active');
    document.getElementById(`tab-${tab}`).classList.add('active');
    history.replaceState(null, '', '#' + tab);
    document.getElementById('tabExplanation').textContent = TAB_EXPLANATIONS[tab];

    // Load tab-specific data
    if (tab === 'upload') { loadDocuments(); }
    else if (tab === 'sitemap') { loadDocuments(); loadCrawlJobs(); loadDomains(); }
    else if (tab === 'snippet') { loadDocuments(); }
    else if (tab === 'sources') { loadSources(); }
}

// File upload
let filesToUpload = [];
let uploadingPlaceholders = []; // {tempId, filename} — optimistic rows shown while POST is in-flight
let placeholderCounter = 0;
const dropzone = document.getElementById('dropzone');
const fileInput = document.getElementById('fileInput');
const uploadBtn = document.getElementById('uploadBtn');

dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('dragover'); });
dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
dropzone.addEventListener('drop', e => { e.preventDefault(); dropzone.classList.remove('dragover'); handleFiles(e.dataTransfer.files); });
fileInput.addEventListener('change', e => handleFiles(e.target.files));

function handleFiles(files) {
    filesToUpload = [...filesToUpload, ...Array.from(files)];
    updateFileList();
}

function updateFileList() {
    const list = document.getElementById('fileList');
    list.innerHTML = '';
    filesToUpload.forEach((file, i) => {
        const item = document.createElement('div');
        item.className = 'file-item';
        item.innerHTML = `<span class="file-name">${file.name} (${(file.size / 1024 / 1024).toFixed(2)} MB)</span><button type="button" class="remove-file" onclick="removeFile(${i})">×</button>`;
        list.appendChild(item);
    });
    uploadBtn.disabled = filesToUpload.length === 0;
    const showFields = filesToUpload.length > 0 ? 'block' : 'none';
    document.getElementById('documentTypeGroup').style.display = showFields;
    document.getElementById('sourceUrlGroup').style.display = showFields;
}

function removeFile(i) { filesToUpload.splice(i, 1); updateFileList(); }

uploadBtn.addEventListener('click', async () => {
    uploadBtn.disabled = true;
    document.getElementById('uploadSpinner').classList.remove('hidden');

    // Snapshot the queue and clear the staging list immediately so the user
    // sees the file move from "ready to upload" to "uploading" right away
    const filesNow = filesToUpload.slice();
    filesToUpload = [];
    updateFileList();

    const documentType = document.getElementById('documentType').value;

    // Render an optimistic placeholder row per file before any network round-trip
    const placeholders = filesNow.map(f => ({
        tempId: `placeholder_${++placeholderCounter}`,
        filename: f.name,
    }));
    uploadingPlaceholders.push(...placeholders);
    if (activeTab !== 'upload') switchTab('upload');
    renderFilteredDocuments('upload', 'documentsTable-upload');

    let successCount = 0;
    for (let i = 0; i < filesNow.length; i++) {
        const file = filesNow[i];
        const placeholder = placeholders[i];
        const fd = new FormData();
        fd.append('file', file);
        fd.append('document_type', documentType);
        const sourceUrl = document.getElementById('sourceUrl').value.trim();
        if (sourceUrl) { fd.append('source_url', sourceUrl); }
        try {
            const resp = await fetch('{{ path('app_kb_api_upload') }}', { method: 'POST', body: fd });
            // Drop this placeholder regardless of success — server is now the source of truth
            uploadingPlaceholders = uploadingPlaceholders.filter(p => p.tempId !== placeholder.tempId);
            if (resp.ok) {
                successCount++;
                await loadDocuments(); // pulls in the new pending/processing row
            } else {
                const d = await resp.json();
                alert(d.error || 'Upload failed');
                renderFilteredDocuments('upload', 'documentsTable-upload');
            }
        } catch (e) {
            uploadingPlaceholders = uploadingPlaceholders.filter(p => p.tempId !== placeholder.tempId);
            alert('Upload error: ' + e.message);
            renderFilteredDocuments('upload', 'documentsTable-upload');
        }
    }
    document.getElementById('uploadSpinner').classList.add('hidden');
    uploadBtn.disabled = filesToUpload.length === 0;
    if (successCount > 0) startAutoRefresh();
});

// Snippet
const snippetText = document.getElementById('snippetText');
const saveSnippetBtn = document.getElementById('saveSnippetBtn');
snippetText.addEventListener('input', () => { saveSnippetBtn.disabled = !snippetText.value.trim(); });

async function saveSnippet() {
    saveSnippetBtn.disabled = true;
    document.getElementById('snippetSpinner').classList.remove('hidden');
    try {
        const resp = await fetch('{{ path('app_kb_api_snippet') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title: document.getElementById('snippetTitle').value.trim(), text: snippetText.value.trim(), source_url: document.getElementById('snippetSourceUrl').value.trim() || undefined }),
        });
        const data = await resp.json();
        if (resp.ok) {
            document.getElementById('snippetTitle').value = '';
            snippetText.value = '';
            document.getElementById('snippetSourceUrl').value = '';
            loadDocuments();
        } else { alert(data.error || 'Failed to save snippet'); }
    } catch (e) { alert('Error: ' + e.message); }
    finally { saveSnippetBtn.disabled = false; document.getElementById('snippetSpinner').classList.add('hidden'); }
}

// Sitemap crawl
async function startCrawl() {
    const url = document.getElementById('sitemapUrl').value.trim();
    if (!url) return;
    document.getElementById('crawlSpinner').classList.remove('hidden');
    try {
        const resp = await fetch('{{ path('app_kb_api_crawl_start') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sitemap_url: url }),
        });
        const data = await resp.json();
        if (resp.ok) { document.getElementById('sitemapUrl').value = ''; loadCrawlJobs(); startCrawlRefresh(); }
        else { alert(data.error || 'Failed to start crawl'); }
    } catch (e) { alert('Error: ' + e.message); }
    finally { document.getElementById('crawlSpinner').classList.add('hidden'); }
}

// Load documents and distribute to tab-specific tables
async function loadDocuments() {
    try {
        const resp = await fetch(`{{ path('app_kb_api_documents') }}?page=1&per_page=500`);
        const data = await resp.json();
        allDocuments = data.documents || [];
        renderFilteredDocuments('upload', 'documentsTable-upload');
        renderFilteredDocuments('web_crawl', 'documentsTable-web_crawl');
        renderFilteredDocuments('snippet', 'documentsTable-snippet');
        const hasPending = allDocuments.some(d => d.status === 'pending' || d.status === 'processing');
        if (hasPending) startAutoRefresh();
        else stopAutoRefresh();
    } catch (e) { console.error('Failed to load documents:', e); }
}

function getFilteredDocs(sourceType) {
    let docs = allDocuments.filter(d => d.source_type === sourceType);
    if (sourceType === 'upload' && docTypeFilter !== 'all') {
        docs = docs.filter(d => d.document_type === docTypeFilter);
    }
    const q = tabSearchQueries[sourceType];
    if (q) {
        const lower = q.toLowerCase();
        docs = docs.filter(d => d.filename.toLowerCase().includes(lower));
    }
    return docs;
}

function renderFilteredDocuments(sourceType, containerId) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const filteredDocs = getFilteredDocs(sourceType);
    const placeholders = sourceType === 'upload' ? uploadingPlaceholders : [];

    if (filteredDocs.length === 0 && placeholders.length === 0) {
        container.innerHTML = '<div class="empty-state"><p>{{ "kb.documents.empty"|trans }}</p></div>';
        renderTabPagination(sourceType, 0);
        updateBulkActionsUI(sourceType);
        return;
    }

    const page = tabPages[sourceType] || 1;
    const totalPages = Math.ceil(filteredDocs.length / DOCS_PER_PAGE);
    if (page > totalPages && totalPages > 0) tabPages[sourceType] = totalPages;
    const start = (tabPages[sourceType] - 1) * DOCS_PER_PAGE;
    const pageItems = filteredDocs.slice(start, start + DOCS_PER_PAGE);
    const selection = tabSelections[sourceType];
    const allVisibleSelected = pageItems.length > 0 && pageItems.every(d => selection.has(d.id));

    let html = '<div class="files-table"><table><thead><tr>';
    html += `<th class="kb-cb-col"><input type="checkbox" class="kb-checkbox" ${allVisibleSelected ? 'checked' : ''} onchange="toggleSelectAll('${sourceType}', this.checked)"></th>`;
    html += '<th>{{ "kb.documents.filename"|trans }}</th><th>{{ "kb.documents.status"|trans }}</th><th>{{ "kb.documents.chunks"|trans }}</th><th>{{ "kb.documents.date"|trans }}</th><th>{{ "action.actions"|trans }}</th></tr></thead><tbody>';

    placeholders.forEach(p => {
        html += `<tr class="row-uploading">
            <td class="kb-cb-col"></td>
            <td class="file-name">${p.filename}</td>
            <td><span class="status-badge status-uploading"><span class="badge-spinner"></span>{{ "kb.documents.uploading"|trans }}</span></td>
            <td>—</td>
            <td>${new Date().toLocaleDateString()}</td>
            <td class="file-actions">—</td>
        </tr>`;
    });

    pageItems.forEach(d => {
        const checked = selection.has(d.id) ? 'checked' : '';
        const statusClass = `status-${d.status}`;
        html += `<tr>
            <td class="kb-cb-col"><input type="checkbox" class="kb-checkbox" ${checked} onchange="toggleDocSelection('${sourceType}', '${d.id}', this.checked)"></td>
            <td class="file-name">${d.filename}</td>
            <td><span class="status-badge ${statusClass}">${d.status}</span>${d.error ? ` <small title="${d.error}" style="color:var(--danger-color);cursor:help;">&#9888;</small>` : ''}</td>
            <td>${d.chunk_count || 0}</td>
            <td>${new Date(d.created_at).toLocaleDateString()}</td>
            <td class="file-actions">${sourceType === 'upload' && d.status === 'completed' ? `<a class="btn btn-small btn-secondary" href="${API_BASE}/documents/${d.id}/download">{{ "action.download"|trans }}</a> ` : ''}${sourceType === 'snippet' ? `<button class="btn btn-small btn-secondary" onclick="viewSnippet('${d.id}')">{{ "action.view"|trans }}</button> <button class="btn btn-small btn-primary" onclick="editSnippet('${d.id}')">{{ "action.edit"|trans }}</button> ` : ''}<button class="btn btn-small btn-danger" onclick="deleteDocument('${d.id}')">{{ "action.delete"|trans }}</button></td>
        </tr>`;
    });

    html += '</tbody></table></div>';
    container.innerHTML = html;
    renderTabPagination(sourceType, filteredDocs.length);
    updateBulkActionsUI(sourceType);
}

function renderTabPagination(sourceType, totalItems) {
    const container = document.getElementById(`pagination-${sourceType}`);
    if (!container) return;
    const pages = Math.ceil(totalItems / DOCS_PER_PAGE);
    const currentPg = tabPages[sourceType] || 1;

    if (pages <= 1) {
        container.innerHTML = totalItems > 0 ? `<div class="kb-pagination-info">${totalItems} document${totalItems !== 1 ? 's' : ''}</div>` : '';
        return;
    }

    const from = ((currentPg - 1) * DOCS_PER_PAGE) + 1;
    const to = Math.min(currentPg * DOCS_PER_PAGE, totalItems);
    let html = `<div class="kb-pagination-info">{{ "kb.documents.showing"|trans|default("Showing") }} ${from}–${to} {{ "kb.documents.of"|trans|default("of") }} ${totalItems}</div>`;
    html += '<div class="kb-pagination">';
    html += `<button ${currentPg === 1 ? 'disabled' : ''} onclick="goToPage('${sourceType}', ${currentPg - 1})">‹ {{ "pagination.previous"|trans|default("Prev") }}</button>`;

    const maxButtons = 7;
    let startPage = Math.max(1, currentPg - 3);
    let endPage = Math.min(pages, startPage + maxButtons - 1);
    if (endPage - startPage < maxButtons - 1) startPage = Math.max(1, endPage - maxButtons + 1);

    if (startPage > 1) html += `<button onclick="goToPage('${sourceType}', 1)">1</button>`;
    if (startPage > 2) html += '<span style="color:var(--text-muted);padding:0 0.3rem;">…</span>';
    for (let i = startPage; i <= endPage; i++) {
        html += `<button class="${i === currentPg ? 'active' : ''}" onclick="goToPage('${sourceType}', ${i})">${i}</button>`;
    }
    if (endPage < pages - 1) html += '<span style="color:var(--text-muted);padding:0 0.3rem;">…</span>';
    if (endPage < pages) html += `<button onclick="goToPage('${sourceType}', ${pages})">${pages}</button>`;
    html += `<button ${currentPg === pages ? 'disabled' : ''} onclick="goToPage('${sourceType}', ${currentPg + 1})">{{ "pagination.next"|trans|default("Next") }} ›</button>`;
    html += '</div>';
    container.innerHTML = html;
}

function goToPage(sourceType, page) {
    tabPages[sourceType] = page;
    renderFilteredDocuments(sourceType, `documentsTable-${sourceType}`);
}

// Selection management
function toggleDocSelection(sourceType, docId, checked) {
    const sel = tabSelections[sourceType];
    if (checked) sel.add(docId); else sel.delete(docId);
    updateBulkActionsUI(sourceType);
    const selectAllCb = document.querySelector(`#documentsTable-${sourceType} thead .kb-checkbox`);
    if (selectAllCb) {
        const pageItems = getFilteredDocs(sourceType).slice(
            (tabPages[sourceType] - 1) * DOCS_PER_PAGE,
            tabPages[sourceType] * DOCS_PER_PAGE
        );
        selectAllCb.checked = pageItems.length > 0 && pageItems.every(d => sel.has(d.id));
    }
}

function toggleSelectAll(sourceType, checked) {
    const sel = tabSelections[sourceType];
    const pageItems = getFilteredDocs(sourceType).slice(
        (tabPages[sourceType] - 1) * DOCS_PER_PAGE,
        tabPages[sourceType] * DOCS_PER_PAGE
    );
    pageItems.forEach(d => { if (checked) sel.add(d.id); else sel.delete(d.id); });
    renderFilteredDocuments(sourceType, `documentsTable-${sourceType}`);
}

function clearSelection(sourceType) {
    tabSelections[sourceType].clear();
    renderFilteredDocuments(sourceType, `documentsTable-${sourceType}`);
}

function updateBulkActionsUI(sourceType) {
    const sel = tabSelections[sourceType];
    const bar = document.getElementById(`bulkActions-${sourceType}`);
    const count = document.getElementById(`bulkCount-${sourceType}`);
    if (!bar) return;
    bar.style.display = sel.size > 0 ? 'flex' : 'none';
    if (count) count.textContent = sel.size + ' {{ "kb.bulk.selected"|trans|default("selected") }}';
}

async function bulkDelete(sourceType) {
    const sel = tabSelections[sourceType];
    if (sel.size === 0) return;
    const cnt = sel.size;
    if (!confirm(`{{ "kb.documents.delete_confirm"|trans }}`.replace('this document', cnt + ' document' + (cnt !== 1 ? 's' : '')))) return;

    try {
        const resp = await fetch(`{{ path('app_knowledge_base') }}api/documents/bulk-delete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ doc_ids: Array.from(sel) }),
        });
        const data = await resp.json();
        if (resp.ok) {
            sel.clear();
            await loadDocuments();
            if (activeTab === 'sources') loadSources();
        } else { alert(data.error || 'Bulk delete failed'); }
    } catch (e) { alert('Bulk delete error: ' + e.message); }
}

// Search & filter handlers
function onSearchInput(sourceType) {
    const input = document.getElementById(`searchInput-${sourceType}`);
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
        tabSearchQueries[sourceType] = input ? input.value.trim() : '';
        tabPages[sourceType] = 1;
        renderFilteredDocuments(sourceType, `documentsTable-${sourceType}`);
    }, 300);
}

function onDocTypeFilterChange() {
    docTypeFilter = document.getElementById('docTypeFilter').value;
    tabPages.upload = 1;
    renderFilteredDocuments('upload', 'documentsTable-upload');
}

async function deleteDocument(docId) {
    if (!confirm('{{ "kb.documents.delete_confirm"|trans }}')) return;
    try {
        await fetch(`{{ path('app_knowledge_base') }}api/documents/${docId}`, { method: 'DELETE' });
        loadDocuments();
        if (activeTab === 'sources') loadSources();
    } catch (e) { alert('Delete failed: ' + e.message); }
}

// Snippet View / Edit
let editingDocId = null;

async function viewSnippet(docId) {
    try {
        const resp = await fetch(`{{ path('app_knowledge_base') }}api/snippet/${docId}/content`);
        const data = await resp.json();
        if (resp.ok) {
            document.getElementById('snippetViewTitleText').textContent = data.title || '(no title)';
            document.getElementById('snippetViewContentText').textContent = data.text || '';
            document.getElementById('snippetViewModal').classList.add('show');
        } else { alert(data.error || 'Failed to load snippet'); }
    } catch (e) { alert('Error: ' + e.message); }
}

function hideSnippetViewModal() {
    document.getElementById('snippetViewModal').classList.remove('show');
}

async function editSnippet(docId) {
    try {
        const resp = await fetch(`{{ path('app_knowledge_base') }}api/snippet/${docId}/content`);
        const data = await resp.json();
        if (resp.ok) {
            editingDocId = docId;
            document.getElementById('snippetEditTitleInput').value = data.title || '';
            document.getElementById('snippetEditTextInput').value = data.text || '';
            document.getElementById('snippetEditModal').classList.add('show');
        } else { alert(data.error || 'Failed to load snippet'); }
    } catch (e) { alert('Error: ' + e.message); }
}

function hideSnippetEditModal() {
    document.getElementById('snippetEditModal').classList.remove('show');
    editingDocId = null;
}

async function saveSnippetEdit() {
    if (!editingDocId) return;
    const btn = document.getElementById('snippetEditSaveBtn');
    btn.disabled = true;
    document.getElementById('snippetEditSpinner').classList.remove('hidden');
    try {
        const resp = await fetch(`{{ path('app_knowledge_base') }}api/snippet/${editingDocId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                title: document.getElementById('snippetEditTitleInput').value.trim(),
                text: document.getElementById('snippetEditTextInput').value.trim(),
            }),
        });
        const data = await resp.json();
        if (resp.ok) {
            hideSnippetEditModal();
            loadDocuments();
        } else { alert(data.error || 'Failed to update snippet'); }
    } catch (e) { alert('Error: ' + e.message); }
    finally {
        btn.disabled = false;
        document.getElementById('snippetEditSpinner').classList.add('hidden');
    }
}

document.getElementById('snippetViewModal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) hideSnippetViewModal();
});
document.getElementById('snippetEditModal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) hideSnippetEditModal();
});

// Load domains
async function loadDomains() {
    try {
        const resp = await fetch('{{ path('app_kb_api_domains') }}');
        const data = await resp.json();
        renderDomainsTable(data.domains || []);
    } catch (e) { console.error('Failed to load domains:', e); }
}

function renderDomainsTable(domains) {
    const container = document.getElementById('domainsTable');
    if (domains.length === 0) {
        container.innerHTML = '<div class="empty-state"><p>{{ "kb.domains.empty"|trans }}</p></div>';
        return;
    }
    let html = '<div class="files-table"><table><thead><tr><th></th><th>{{ "kb.domains.domain"|trans }}</th><th>{{ "kb.domains.pages"|trans }}</th><th>{{ "kb.domains.chunks"|trans }}</th><th>{{ "action.actions"|trans }}</th></tr></thead><tbody>';
    domains.forEach(d => {
        html += `<tr class="domain-row" onclick="toggleDomain(this)">
            <td><i class="fas fa-chevron-right domain-toggle"></i></td>
            <td>${d.domain}</td>
            <td>${d.page_count}</td>
            <td>${d.chunk_count}</td>
            <td class="file-actions"><button class="btn btn-small btn-danger" onclick="event.stopPropagation(); deleteDomain('${d.domain}', ${d.page_count})">{{ "action.delete"|trans }}</button></td>
        </tr>`;
    });
    html += '</tbody></table></div>';
    container.innerHTML = html;
}

function toggleDomain(row) {
    const toggle = row.querySelector('.domain-toggle');
    toggle.classList.toggle('expanded');
}

async function deleteDomain(domain, pageCount) {
    if (!confirm(`{{ "kb.domains.delete_confirm"|trans }}`.replace('{domain}', domain).replace('{count}', pageCount))) return;
    try {
        await fetch(`{{ path('app_knowledge_base') }}api/domains/${domain}`, { method: 'DELETE' });
        loadDomains();
        loadSources();
    } catch (e) { alert('Delete failed: ' + e.message); }
}

// Load sources
async function loadSources() {
    try {
        const resp = await fetch('{{ path('app_kb_api_sources') }}');
        const data = await resp.json();
        renderSourcesTable(data.sources || []);
    } catch (e) { console.error('Failed to load sources:', e); }
}

function renderSourcesTable(sources) {
    const container = document.getElementById('sourcesTable');
    if (sources.length === 0) {
        container.innerHTML = '<div class="empty-state"><p>{{ "kb.sources.empty"|trans }}</p></div>';
        return;
    }
    let html = '<div class="files-table"><table><thead><tr><th>{{ "kb.sources.source_file"|trans }}</th><th>{{ "kb.sources.type"|trans }}</th><th>{{ "kb.sources.source_type"|trans }}</th><th>{{ "kb.sources.chunks"|trans }}</th><th>{{ "kb.sources.indexed_at"|trans }}</th></tr></thead><tbody>';
    sources.forEach(s => {
        html += `<tr><td>${s.source_file}</td><td>${s.document_type}</td><td>${s.source_type}</td><td>${s.chunk_count}</td><td>${s.indexed_at ? new Date(s.indexed_at).toLocaleDateString() : '-'}</td></tr>`;
    });
    html += '</tbody></table></div>';
    container.innerHTML = html;
}

// Load crawl jobs
async function loadCrawlJobs() {
    try {
        const resp = await fetch('{{ path('app_kb_api_crawl_list') }}');
        const data = await resp.json();
        renderCrawlJobs(data.crawl_jobs || []);
    } catch (e) { console.error('Failed to load crawl jobs:', e); }
}

function renderCrawlJobs(jobs) {
    const container = document.getElementById('crawlJobsList');
    if (jobs.length === 0) {
        container.innerHTML = '<div class="empty-state"><p>{{ "kb.sitemap.no_crawls"|trans }}</p></div>';
        return;
    }
    let html = '<div class="files-table"><table><thead><tr><th>{{ "kb.sitemap.url"|trans }}</th><th>{{ "kb.documents.status"|trans }}</th><th>{{ "kb.sitemap.progress"|trans }}</th><th>{{ "kb.sitemap.started"|trans }}</th><th>{{ "action.actions"|trans }}</th></tr></thead><tbody>';
    jobs.forEach(j => {
        const statusClass = `status-${j.status}`;
        const progress = j.total_urls > 0 ? `${(j.indexed_urls || 0) + (j.failed_urls || 0)}/${j.total_urls}` : '-';
        html += `<tr>
            <td class="file-name" title="${j.sitemap_url}">${j.sitemap_url}</td>
            <td><span class="status-badge ${statusClass}">${j.status}</span></td>
            <td>${progress}</td>
            <td>${new Date(j.created_at).toLocaleDateString()}</td>
            <td class="file-actions"><button class="btn btn-small btn-danger" onclick="deleteCrawlJob('${j.id}')">{{ "action.delete"|trans }}</button></td>
        </tr>`;
    });
    html += '</tbody></table></div>';
    container.innerHTML = html;

    const hasActive = jobs.some(j => ['discovering', 'crawling', 'processing'].includes(j.status));
    if (hasActive) startCrawlRefresh();
    else stopCrawlRefresh();
}

async function deleteCrawlJob(jobId) {
    if (!confirm('{{ "kb.sitemap.delete_confirm"|trans }}')) return;
    try {
        await fetch(`{{ path('app_knowledge_base') }}api/crawl/${jobId}`, { method: 'DELETE' });
        loadCrawlJobs();
        loadDomains();
        loadSources();
    } catch (e) { alert('Delete failed: ' + e.message); }
}

// Auto-refresh
function startAutoRefresh() { if (!refreshInterval) refreshInterval = setInterval(() => loadDocuments(), 5000); }
function stopAutoRefresh() { if (refreshInterval) { clearInterval(refreshInterval); refreshInterval = null; } }
function startCrawlRefresh() { if (!crawlRefreshInterval) crawlRefreshInterval = setInterval(() => { loadCrawlJobs(); loadDomains(); }, 5000); }
function stopCrawlRefresh() { if (crawlRefreshInterval) { clearInterval(crawlRefreshInterval); crawlRefreshInterval = null; } }

// Handle browser back/forward navigation
window.addEventListener('hashchange', () => {
    const hash = window.location.hash.replace('#', '');
    if (VALID_TABS.includes(hash) && hash !== activeTab) switchTab(hash);
});

// Initial load — restore tab from URL hash
document.addEventListener('DOMContentLoaded', () => {
    const hash = window.location.hash.replace('#', '');
    const initialTab = VALID_TABS.includes(hash) ? hash : 'upload';
    switchTab(initialTab);
});
</script>
{% endblock %}
