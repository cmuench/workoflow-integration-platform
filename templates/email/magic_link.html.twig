<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Workoflow Login Link</title>
    <!--[if mso]>
    <style type="text/css">
        body, table, td { font-family: Arial, Helvetica, sans-serif !important; }
    </style>
    <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #f4f4f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f4f4f5;">
        <tr>
            <td align="center" style="padding: 40px 20px 20px;">

                <!-- Header with orange gradient bar and Workoflow logo -->
                <table role="presentation" cellpadding="0" cellspacing="0" width="600" style="max-width: 600px;">
                    <tr>
                        <td style="background: #ff6b35; height: 4px; border-radius: 8px 8px 0 0; font-size: 1px; line-height: 1px;">&nbsp;</td>
                    </tr>
                </table>

                <!-- Main card -->
                <table role="presentation" cellpadding="0" cellspacing="0" width="600" style="max-width: 600px; background-color: #ffffff; border: 1px solid #e4e4e7; border-top: none;">

                    <!-- Logo and brand -->
                    <tr>
                        <td style="padding: 32px 40px 16px;" align="center">
                            <img src="{{ app_url }}/images/workoflow-logo-email.png" alt="Workoflow" width="64" height="64" style="display: block; width: 64px; height: 64px;">
                        </td>
                    </tr>
                    <tr>
                        <td align="center" style="padding: 0 40px 8px;">
                            <p style="margin: 0; font-size: 11px; font-weight: 600; letter-spacing: 2px; color: #ff6b35; text-transform: uppercase;">Workoflow Integration Platform</p>
                        </td>
                    </tr>

                    <!-- Divider -->
                    <tr>
                        <td style="padding: 0 40px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td style="border-top: 1px solid #e4e4e7; font-size: 1px; line-height: 1px; height: 1px;">&nbsp;</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Greeting -->
                    <tr>
                        <td style="padding: 24px 40px 8px;" align="center">
                            <h1 style="margin: 0; font-size: 22px; font-weight: 600; color: #18181b;">Hello {{ userName }}</h1>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 0 40px 24px;" align="center">
                            <p style="margin: 0; font-size: 15px; color: #71717a; line-height: 1.5;">You requested a login link for your Workoflow account. Click the button below to sign in.</p>
                        </td>
                    </tr>

                    <!-- CTA Button -->
                    <tr>
                        <td style="padding: 8px 40px 32px;" align="center">
                            <!--[if mso]>
                            <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{ magicLink }}" style="height:48px;width:260px;" arcsize="17%" fillcolor="#ff6b35" stroke="f">
                                <w:anchorlock/>
                                <center style="color:#ffffff;font-size:16px;font-weight:600;">Sign in to Workoflow</center>
                            </v:roundrect>
                            <![endif]-->
                            <!--[if !mso]><!-->
                            <a href="{{ magicLink }}" style="display: inline-block; padding: 14px 40px; background-color: #ff6b35; color: #ffffff; text-decoration: none; border-radius: 8px; font-size: 16px; font-weight: 600; letter-spacing: 0.3px;">Sign in to Workoflow</a>
                            <!--<![endif]-->
                        </td>
                    </tr>

                    <!-- Validity note -->
                    <tr>
                        <td style="padding: 0 40px 20px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #fef7f3; border: 1px solid #fed7c7; border-radius: 8px;">
                                <tr>
                                    <td style="padding: 14px 20px;">
                                        <p style="margin: 0; font-size: 13px; color: #71717a; text-align: center; line-height: 1.5;">
                                            This link is valid for <strong style="color: #18181b;">24 hours</strong> and can be used multiple times within that period.
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Fallback URL -->
                    <tr>
                        <td style="padding: 0 40px 24px;">
                            <p style="margin: 0; font-size: 12px; color: #a1a1aa; line-height: 1.5;">
                                If the button doesn't work, copy and paste this URL into your browser:<br>
                                <a href="{{ magicLink }}" style="color: #ff6b35; word-break: break-all;">{{ magicLink }}</a>
                            </p>
                        </td>
                    </tr>

                    <!-- Divider -->
                    <tr>
                        <td style="padding: 0 40px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td style="border-top: 1px solid #e4e4e7; font-size: 1px; line-height: 1px; height: 1px;">&nbsp;</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Security note -->
                    <tr>
                        <td style="padding: 20px 40px 24px;">
                            <p style="margin: 0; font-size: 12px; color: #a1a1aa; text-align: center;">
                                If you didn't request this link, you can safely ignore this email.
                            </p>
                        </td>
                    </tr>
                </table>

                <!-- Footer with valantic branding -->
                <table role="presentation" cellpadding="0" cellspacing="0" width="600" style="max-width: 600px;">
                    <tr>
                        <td align="center" style="padding: 24px 40px 8px;">
                            <img src="{{ app_url }}/images/valantic-logo-email.png" alt="valantic" width="100" style="display: block; width: 100px; height: auto; opacity: 0.4;">
                        </td>
                    </tr>
                    <tr>
                        <td align="center" style="padding: 0 40px 20px;">
                            <p style="margin: 0; font-size: 11px; color: #a1a1aa;">
                                Workoflow Integration Platform &mdash; a valantic product
                            </p>
                        </td>
                    </tr>
                </table>

            </td>
        </tr>
    </table>
</body>
</html>
