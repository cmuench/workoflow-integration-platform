<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Workoflow Login Link</title>
    <!--[if mso]>
    <style type="text/css">
        body, table, td { font-family: Arial, Helvetica, sans-serif !important; }
    </style>
    <![endif]-->
</head>
<body style="margin: 0; padding: 0; background-color: #f4f4f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f4f4f5;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <table role="presentation" cellpadding="0" cellspacing="0" width="600" style="max-width: 600px; background-color: #ffffff; border-radius: 8px; border: 1px solid #e4e4e7;">
                    <tr>
                        <td style="padding: 40px 40px 20px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td align="center" style="padding-bottom: 24px;">
                                        <!--[if mso]>
                                        <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" style="height:48px;width:48px;" arcsize="21%" fillcolor="#ff6b35" stroke="f">
                                            <v:textbox inset="0,0,0,0"><center style="color:#ffffff;font-size:24px;font-weight:bold;">W</center></v:textbox>
                                        </v:roundrect>
                                        <![endif]-->
                                        <!--[if !mso]><!-->
                                        <div style="width: 48px; height: 48px; background-color: #ff6b35; border-radius: 10px; display: inline-block; text-align: center; line-height: 48px; font-size: 24px; font-weight: bold; color: #ffffff;">W</div>
                                        <!--<![endif]-->
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center">
                                        <h1 style="margin: 0 0 8px; font-size: 24px; font-weight: 600; color: #18181b;">Hello {{ userName }}</h1>
                                        <p style="margin: 0; font-size: 16px; color: #71717a;">You requested a login link for Workoflow</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 20px 40px;" align="center">
                            <!--[if mso]>
                            <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{ magicLink }}" style="height:48px;width:240px;" arcsize="17%" fillcolor="#ff6b35" stroke="f">
                                <w:anchorlock/>
                                <center style="color:#ffffff;font-size:16px;font-weight:600;">Sign in to Workoflow</center>
                            </v:roundrect>
                            <![endif]-->
                            <!--[if !mso]><!-->
                            <a href="{{ magicLink }}" style="display: inline-block; padding: 14px 32px; background-color: #ff6b35; color: #ffffff; text-decoration: none; border-radius: 8px; font-size: 16px; font-weight: 600; letter-spacing: 0.3px;">Sign in to Workoflow</a>
                            <!--<![endif]-->
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 16px 40px 20px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f4f4f5; border-radius: 8px;">
                                <tr>
                                    <td style="padding: 16px 20px;">
                                        <p style="margin: 0; font-size: 13px; color: #71717a; text-align: center;">
                                            This link is valid for <strong style="color: #18181b;">24 hours</strong> and can be used multiple times within that period.
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 0 40px;">
                            <p style="margin: 0; font-size: 12px; color: #a1a1aa; line-height: 1.5;">
                                If the button doesn't work, copy and paste this URL into your browser:<br>
                                <a href="{{ magicLink }}" style="color: #ff6b35; word-break: break-all;">{{ magicLink }}</a>
                            </p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 30px 40px 40px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-top: 1px solid #e4e4e7;">
                                <tr>
                                    <td style="padding-top: 20px;">
                                        <p style="margin: 0; font-size: 12px; color: #a1a1aa; text-align: center;">
                                            If you didn't request this link, you can safely ignore this email.
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
