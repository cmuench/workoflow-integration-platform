<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Workoflow Login Link</title>
</head>
<body style="margin: 0; padding: 0; background-color: #0f1117; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #0f1117;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <table role="presentation" cellpadding="0" cellspacing="0" width="600" style="max-width: 600px; background-color: #1a1d27; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
                    <tr>
                        <td style="padding: 40px 40px 20px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td align="center" style="padding-bottom: 24px;">
                                        <div style="width: 48px; height: 48px; background-color: #ff6b35; border-radius: 10px; display: inline-block; text-align: center; line-height: 48px; font-size: 24px; font-weight: bold; color: white;">W</div>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center">
                                        <h1 style="margin: 0 0 8px; font-size: 24px; font-weight: 600; color: #ffffff;">Hello {{ userName }}</h1>
                                        <p style="margin: 0; font-size: 16px; color: #9ca3af;">You requested a login link for Workoflow</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 20px 40px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td align="center" style="padding: 24px 0;">
                                        <a href="{{ magicLink }}" style="display: inline-block; padding: 14px 32px; background-color: #ff6b35; color: #ffffff; text-decoration: none; border-radius: 8px; font-size: 16px; font-weight: 600; letter-spacing: 0.3px;">Sign in to Workoflow</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 0 40px 20px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: rgba(255,255,255,0.05); border-radius: 8px;">
                                <tr>
                                    <td style="padding: 16px 20px;">
                                        <p style="margin: 0; font-size: 13px; color: #9ca3af; text-align: center;">
                                            This link is valid for <strong style="color: #ffffff;">24 hours</strong> and can be used multiple times within that period.
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 0 40px;">
                            <p style="margin: 0; font-size: 12px; color: #6b7280; line-height: 1.5;">
                                If the button doesn't work, copy and paste this URL into your browser:<br>
                                <a href="{{ magicLink }}" style="color: #ff6b35; word-break: break-all;">{{ magicLink }}</a>
                            </p>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 30px 40px 40px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-top: 1px solid rgba(255,255,255,0.1);">
                                <tr>
                                    <td style="padding-top: 20px;">
                                        <p style="margin: 0; font-size: 12px; color: #6b7280; text-align: center;">
                                            If you didn't request this link, you can safely ignore this email.
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
